{
  "scripts": {
    "lint": "eslint . && prettier --check ."
  },
  "prettier": {
    "overrides": [
      {
        "files": [
          "**/package.json"
        ],
        "options": {
          "plugins": [
            "prettier-plugin-packagejson"
          ]
        }
      },
      {
        "files": [
          "**/*.md"
        ],
        "options": {
          "proseWrap": "always"
        }
      }
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=11.8.0"
    }
  }
}
